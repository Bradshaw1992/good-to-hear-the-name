# Copy to scripts/.env and fill in. scripts/.env is gitignored.
# Get X keys at developer.x.com (free tier is fine: 1500 posts/month write)
#   - Create a Project + App, enable OAuth 1.0a, Read+Write permission
#   - Generate API Key/Secret and Access Token/Secret under "Keys and tokens"
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# Bluesky: handle is e.g. goodtohearthename.co.uk (or *.bsky.social).
# App password is NOT your login password. Generate one at
#   Settings -> Privacy and Security -> App Passwords -> Add App Password
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=
